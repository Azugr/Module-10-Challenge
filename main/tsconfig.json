{
  "compilerOptions": {
    "target": "es6",                          // Target ECMAScript 2015 (ES6)
    "module": "commonjs",                     // Use CommonJS module system (for Node.js)
    "outDir": "./dist",                       // Output directory for compiled JavaScript files
    "rootDir": "./src",                       // Root directory for your TypeScript files
    "strict": true,                           // Enable all strict type-checking options
    "esModuleInterop": true,                  // Enable compatibility between CommonJS and ES Modules
    "forceConsistentCasingInFileNames": true, // Enforce consistent casing for file imports
    "skipLibCheck": true,                     // Skip type checking of declaration files
    "resolveJsonModule": true,                // Allow importing JSON files
    "typeRoots": ["./node_modules/@types", "src/types"] // Include type definitions from `types`
  },
  "include": ["src/**/*"],                   // Include all TypeScript files in the `src` folder
  "exclude": ["node_modules"]                // Exclude `node_modules` from compilation
}
